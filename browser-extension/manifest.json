{
  "manifest_version": 3,
  "name": "ApplyMate — Autonomous Application Assistant",
  "version": "0.2.0",
  "description": "Detects Greenhouse and Lever application forms, fills them from your ApplyMate profile, and submits applications you've authorized with a right swipe.",
  "key": "",
  "action": {
    "default_title": "ApplyMate — Application Assistant",
    "default_popup": "dist/panel.html"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.greenhouse.io/*",
        "*://*.grnh.se/*",
        "*://*.lever.co/*",
        "http://localhost/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "*://*.greenhouse.io/*",
    "*://*.grnh.se/*",
    "*://*.lever.co/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://localhost:3000/*"
    ]
  }
}
